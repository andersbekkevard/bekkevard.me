---
import type { CollectionEntry } from "astro:content";
import type { Page } from "astro";
import IconArrowLeft from "@/assets/icons/IconArrowLeft.svg";
import IconArrowRight from "@/assets/icons/IconArrowRight.svg";
import LinkButton from "./LinkButton.astro";

export interface Props {
  page: Page<CollectionEntry<"blog">>;
}

const { page } = Astro.props;
---

{
  page.lastPage > 1 && (
    <nav
      class="mt-auto mb-8 flex flex-col items-center justify-center gap-3 sm:flex-row"
      aria-label="Pagination"
    >
      <LinkButton
        disabled={!page.url.prev}
        href={page.url.prev as string}
        class:list={[
          "min-h-11 min-w-24 select-none rounded-sm px-3 py-2 text-center",
          { "opacity-50": !page.url.prev },
        ]}
        ariaLabel="Previous"
      >
        <IconArrowLeft class="inline-block" />
        Prev
      </LinkButton>
      <span class="text-sm sm:text-base">{page.currentPage} / {page.lastPage}</span>
      <LinkButton
        disabled={!page.url.next}
        href={page.url.next as string}
        class:list={[
          "min-h-11 min-w-24 select-none rounded-sm px-3 py-2 text-center",
          { "opacity-50": !page.url.next },
        ]}
        ariaLabel="Next"
      >
        Next
        <IconArrowRight class="inline-block" />
      </LinkButton>
    </nav>
  )
}
