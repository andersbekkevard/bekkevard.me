---
import { getCollection } from "astro:content";
import Footer from "@/components/Footer.astro";
import Header from "@/components/Header.astro";
import { SITE } from "@/consts";
import Layout from "@/layouts/Layout.astro";
import getSortedPosts from "@/utils/getSortedPosts";
import { getPath } from "@/utils/getPath";
import dayjs from "dayjs";

const posts = await getCollection("blog", ({ data }) => !data.draft);
const sortedPosts = getSortedPosts(posts);
---

<Layout title={`Posts | ${SITE.title}`} description="All blog posts.">
  <Header />
  <main id="main-content" class="mx-auto w-full max-w-3xl px-4 pb-8">
    <h1 class="text-xl font-bold mt-4 mb-4">Posts</h1>
    <ul>
      {sortedPosts.map((post) => {
        const date = dayjs(post.data.pubDatetime).format("YYYY-MM-DD");
        return (
          <li class="flex gap-4 py-1.5 text-sm">
            <time datetime={post.data.pubDatetime.toISOString()} class="shrink-0 tabular-nums text-foreground/50">
              {date}
            </time>
            <a href={getPath(post.id, post.filePath)} class="truncate">
              {post.data.title}
            </a>
          </li>
        );
      })}
    </ul>
  </main>
  <Footer />
</Layout>
